# ========================================
# JABR Publication Consultancy
# Environment Configuration Template
# ========================================
# IMPORTANT: Do NOT commit the actual .env file
# Create a .env file locally with real values

# ========== SERVER CONFIGURATION ==========
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ========== SECURITY KEYS ==========
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=your-super-secret-api-key-here-min-32-characters
JWT_SECRET=your-jwt-secret-key-here-min-32-characters
CSRF_SECRET=your-csrf-secret-key-here-min-32-characters
SESSION_SECRET=your-session-secret-key-here-min-32-characters

# ========== EMAIL CONFIGURATION ==========
# Use environment-specific email service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@jabrpublication.com
ADMIN_EMAIL=admin@jabrpublication.com

# ========== COMPANY INFORMATION ==========
COMPANY_NAME=JABR Publication Consultancy
COMPANY_EMAIL=info@jabrpublication.com
COMPANY_PHONE=+91-XXXX-XXXXXX
COMPANY_WEBSITE=https://jabrpublication.com
COMPANY_TIMEZONE=Asia/Kolkata

# ========== DATABASE CONFIGURATION ==========
# For future integration with MongoDB, PostgreSQL, Firebase, etc.
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/jabr_db
DATABASE_BACKUP_URL=backup-database-url-here

# ========== THIRD-PARTY INTEGRATIONS ==========
# Email service integrations
SENDGRID_API_KEY=your-sendgrid-api-key
MAILGUN_API_KEY=your-mailgun-api-key

# Analytics and monitoring
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# File storage
AWS_S3_BUCKET=jabr-uploads
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ========== CLOUDFLARE CONFIGURATION ==========
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# ========== RATE LIMITING ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========== FILE UPLOAD RESTRICTIONS ==========
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpeg,jpg,png

# ========== SECURITY SETTINGS ==========
# HTTPS enforcement
FORCE_HTTPS=true
HSTS_MAX_AGE=31536000

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_URI=https://jabrpublication.com/api/csp-report

# ========== CORS CONFIGURATION ==========
CORS_ORIGIN=https://jabrpublication.com
ALLOWED_ORIGINS=https://jabrpublication.com,https://www.jabrpublication.com

# ========== DEBUG MODE ==========
DEBUG=false
VERBOSE_LOGGING=false

# ========== FEATURE FLAGS ==========
ENABLE_CONTACT_FORM=true
ENABLE_NEWSLETTER=true
ENABLE_FILE_UPLOADS=true
MAINTENANCE_MODE=false

# ========== MONITORING & LOGGING ==========
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000
